rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwnerOrAdmin(uid) {
      return isOwner(uid) || isAdmin();
    }

    function isSafeUserCreate(userId) {
      return request.resource.data.uid == userId
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'nickname',
          'photoURL',
          'points',
          'tier',
          'isAdmin',
          'isChallenger',
          'introduction',
          'department',
          'year',
          'interests',
          'skills',
          'createdAt'
        ])
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.points == 0
        && request.resource.data.tier == 'bronze'
        && request.resource.data.isAdmin == false
        && request.resource.data.isChallenger == false
        && (
          !request.resource.data.keys().hasAny(['isTestAccount']) ||
          request.resource.data.isTestAccount == false
        );
    }

    function userFieldsUnchanged() {
      return request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.isChallenger == resource.data.isChallenger
        && request.resource.data.points == resource.data.points
        && request.resource.data.tier == resource.data.tier
        && request.resource.data.isTestAccount == resource.data.isTestAccount;
    }

    function isSafeUserProfileUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'nickname',
        'photoURL',
        'introduction',
        'department',
        'year',
        'interests',
        'skills'
      ]);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isSafeUserCreate(userId);
      allow update: if isOwner(userId) && userFieldsUnchanged() && isSafeUserProfileUpdate();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /userPrivate/{userId} {
      allow read, create, update, delete: if isOwnerOrAdmin(userId);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.receiverId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']) &&
        request.resource.data.isRead == true;
      allow delete: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.uploadedBy == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /presence/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /pointEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
